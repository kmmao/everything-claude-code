{
  "version": 1,
  "target": "claude",
  "profile": "full",
  "exclude": [
    "capability:supply-chain",
    "capability:machine-learning",
    "capability:media",
    "capability:social",
    "capability:content",
    "capability:operators",
    "capability:orchestration",
    "lang:swift"
  ],
  "options": {
    "keep_rules": ["common", "typescript", "web", "python", "java"],
    "exclude_rules_files": ["web/hooks.md"],
    "exclude_hooks": [
      "pre:governance-capture",
      "pre:observe:continuous-learning",
      "post:edit:design-quality-check",
      "post:governance-capture",
      "post:observe:continuous-learning",
      "post:mcp-health-check",
      "stop:desktop-notify",
      "stop:evaluate-session",
      "post:session-activity-tracker"
    ]
  }
}
